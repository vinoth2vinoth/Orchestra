{
  "name": "doc-architect",
  "version": "1.0.0",
  "description": "Architectura-aware documentation generator powered by DeepSeek.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "doc-architect": "./dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
