    "@ai-sdk/deepseek": "^0.0.1",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsx": "^4.7.2",
    "@types/node": "^20.12.7",
    "@types/fs-extra": "^11.0.4"
  }
